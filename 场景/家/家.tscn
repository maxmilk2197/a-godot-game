[node name="AI聊天界面" type="Control" parent="." unique_id=51273642 node_paths=PackedStringArray("_输入框", "_状态标签", "_设置URL输入", "_设置密钥输入", "_设置模型输入", "_设置取消按钮", "_设置保存按钮")]
